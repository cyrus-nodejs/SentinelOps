{
  "$schema": "https://turbo.build",
  "tasks": {
    "db:generate": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "dependsOn": ["db:generate"],

      "cache": false,
      "persistent": true
    },
    "lint": {}
  }
}
